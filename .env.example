# UltraFaceswap environment variables
# Copy to .env and adjust as needed

# FaceFusion (optional) - path to FaceFusion repo root
# ULTRAFACESWAP_FACEFUSION_PATH=/path/to/facefusion

# Output directory for swap results
# ULTRAFACESWAP_OUTPUT=/tmp/ultrafaceswap_output

# Models directory
# ULTRAFACESWAP_MODELS=models
